
    <div class="row gap-4">
      <wc-input name="[= fullName =]"
        lbl-label="[= properSuffix =]"
        type="radio"
        radio-group-class="row modern"
        value="{{[= record =].[= suffix =]}}">
        {% set [= suffix =] = coalesce([= record =], "[= suffix =]", "") %}
        {% for item in Lookups.[= uiLookup =].item_list %}
        <option value="{{item.value}}"{% if [= suffix =] == item.value %} checked{% endif %}>{{item.key}}</option>
        {% endfor %}
      </wc-input>
    </div>
