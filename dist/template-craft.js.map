export default "\n    <div class=\"row gap-4\">\n      <wc-input name=\"[= fullName =]\"\n        lbl-label=\"[= properSuffix =]\"\n        type=\"radio\"\n        radio-group-class=\"row modern\"\n        value=\"{{[= record =].[= suffix =]}}\">\n        {% set [= suffix =] = coalesce([= record =], \"[= suffix =]\", \"\") %}\n        {% for item in Lookups.[= uiLookup =].item_list %}\n        <option value=\"{{item.value}}\"{% if [= suffix =] == item.value %} checked{% endif %}>{{item.key}}</option>\n        {% endfor %}\n      </wc-input>\n    </div>\n";