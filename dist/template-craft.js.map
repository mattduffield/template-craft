export default "<h2>[= proper =]</h2>\n      <div class=\"row flex-wrap p-4 gap-4 border border-solid rounded-md primary-bg-border-color\">\n        {% if Record.[= propName =] %}\n          {% for item in Record.[= propName =] %}\n           <div class=\"theme-aqua flex flex-col p-4 gap-4 xw-300 border border-solid rounded-md primary-border-color card\">\n            [= arrayHTML =]\n          </div>\n          {% endfor %}\n        {% else %}\n          <div class=\"no-data p-8 flex flex-col flex-1 justify-center items-center\">\n            NO DATA\n          </div>\n        {% endif %}\n      </div>";