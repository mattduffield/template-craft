export default "\n    <div class=\"row gap-4\">\n      <wc-select name=\"[= fullName =]\"\n        lbl-label=\"[= properSuffix =]\"\n        class=\"col-1\"\n        [= required =]>\n        <option value=\"\">Choose...</option>\n        {% set [= suffix =] = Record.[= fullName =] %}\n        {% for item in Lookups.[= uiLookup =].item_list %}\n        <option value=\"{{item.value}}\"{% if [= suffix =] == item.value %} selected{% endif %}>{{item.key}}</option>\n        {% endfor %}\n      </wc-select>\n    </div>\n";