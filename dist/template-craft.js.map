export default "\n    <div class=\"row gap-4\">\n      <wc-input name=\"[= fullName =]\"\n        lbl-label=\"[= properSuffix =]\"\n        type=\"radio\"\n        radio-group-class=\"row modern\"\n        value=\"{{[= record =].[= suffix =]}}\">\n[% for val in enumValues %]\n          <option value=\"[= val =]\">[= val | proper =]</option>\n[% endfor %]\n      </wc-input>\n    </div>\n";