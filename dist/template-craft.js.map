export default "\n    <div class=\"row gap-4\">\n      <wc-select name=\"[= fullName =]\"\n        lbl-label=\"[= properSuffix =]\"\n        class=\"col-1\"\n        [= required =]>\n        <option value=\"\">Choose...</option>\n[% for val in enumValues %]\n          <option value=\"[= val =]\">[= val | proper =]</option>\n[% endfor %]\n      </wc-select>\n    </div>\n";