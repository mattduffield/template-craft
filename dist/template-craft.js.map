export default "<fieldset class=\"row flex-wrap p-4 gap-4 border border-solid rounded-md primary-bg-border-color\">\n        <legend class=\"text-lg\">[= proper =]</legend>\n\n        <div class=\"flex flex-row flex-1 justify-end\">\n            <a class=\"underline\"\n               hx-boost=\"true\"\n               href=\"/api/generate_table_row_fragment_by_schema/{{Template.CollectionName}}\"\n               hx-target=\"#[= tbodyID =]\"\n               hx-swap=\"beforeend\"\n               hx-indicator=\"#content-loader\"\n               hx-push-url=\"false\"\n               hx-vals=\"js:{ index: countElements('#[= tbodyID =] tr'), schema_slug: '{{Template.Schema}}', property_name: '[= propName =]', record_id: '{{RecordID}}', mode: 'add' }\"\n               _=\"on htmx:afterRequest if detail.successful then\n                  set elem to the first <.no-data/>\n                  if elem\n                    transition the elem's opacity to 0 then settle then remove the elem\n                  end\n                end\">\n              Add New\n            </a>\n          </div>\n\n        <table class=\"w-full\">\n          <thead class=\"component-bg-color\">\n            <tr>\n              [= thHTML =]\n              <th class=\"p-2 text-align-left\">Actions</th>\n            </tr>\n          </thead>\n          <tbody id=\"[= tbodyID =]\">\n          {% if Record.[= propName =] %}\n            {% for item in Record.[= propName =] %}\n            <tr>\n              [= tdHTML =]\n              <td class=\"p-2 component-border-color border-b-solid border-b-2\">\n                <a class=\"underline cursor-pointer mr-2\"\n                  hx-boost=\"true\"\n                  href=\"/api/generate_table_row_fragment_by_schema/{{Template.CollectionName}}\"\n                  hx-target=\"closest tr\"\n                  hx-swap=\"outerHTML\"\n                  hx-indicator=\"#content-loader\"\n                  hx-push-url=\"false\"\n                  hx-vals=\"js:{ index: '{%forloop.Counter0%}', schema_slug: '{{Template.Schema}}', property_name: '[= propName =]', record_id: '{{RecordID}}', mode: 'edit' }\">\n                  Edit\n                </a>\n                <a class=\"underline cursor-pointer\"\n                  hx-delete=\"/api/{{Template.CollectionName}}/{{RecordID}}/[= propName =]/{%forloop.Counter0%}\"\n                  hx-target=\"#viewport\"\n                  hx-swap=\"none\"\n                  hx-indicator=\"#content-loader\"\n                  hx-params=\"csrf_token\"\n                  hx-headers='{ \"X-CSRF-Token\": \"{{CSRFToken}}\" }'\n                  hx-push-url=\"false\"\n                  hx-trigger=\"confirm:delete\"\n                  _=\"on click\n                    set result to wc.Prompt.question({ 'title': 'Confirm Remove?', 'text': 'Are you sure you want to remove?' })\n                    if result\n                      trigger 'confirm:delete'\n                    end\n                  end\n                  on htmx:afterRequest if detail.successful then\n                     set elem to the closest <tr />\n                     transition the elem's opacity to 0 then settle then remove the elem\n                  end\">\n                  Remove\n                </a>\n              </td>\n            </tr>\n            {% endfor %}\n          {% else %}\n          <tr>\n            <td>NO DATA</td>\n          </tr>\n          {% endif %}\n          </tbody>\n        </table>\n        </fieldset>";