export default "\n    <div class=\"row gap-4\">\n      <wc-select name=\"[= fullName =]\"\n        mode=\"chip\"\n        class=\"col-1\"\n        lbl-label=\"[= properSuffix =]\"\n        multiple\n        [= required =]>\n        {% set [= suffix =] = Record.[= fullName =] %}\n        {% for item in Lookups.[= uiLookup =].item_list %}\n        <option value=\"{{item.value}}\"{% if [= suffix =] == item.value %} selected{% endif %}>{{item.value}}</option>\n        {% endfor %}\n      </wc-select>\n    </div>\n";