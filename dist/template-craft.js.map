export default "{%extends \"__template_name__\"%}\n\n  {%block pageContent%}\n  <wc-table-skeleton _=\"on 'wc-tabulator:ready' from body\n                        WaveHelpers.waitForThenHideAndShow('#table-skeleton', '.page-content', 3000, 500)\n                     end\">\n  </wc-table-skeleton>\n\n  <div class=\"page-content flex flex-col flex-1 py-2 px-3 gap-2 hidden\">\n    <wc-breadcrumb>\n      <wc-breadcrumb-item label=\"\" link=\"/{{Template.RoutePrefix}}/home\"></wc-breadcrumb-item>\n      <wc-breadcrumb-item label=\"[= properCollection =]\" link=\"\"></wc-breadcrumb-item>\n    </wc-breadcrumb>\n\n    <div class=\"card p-4\">\n      <div class=\"col-md-12\"\n          hx-boost=\"true\"\n          hx-target=\"#viewport\"\n          hx-swap=\"innerHTML transition:true\"\n          hx-push-url=\"true\"\n          hx-indicator=\"#content-loader\"\n          >\n        <div class=\"row-1 justify-end items-center mb-2\">\n          <a class=\"underline cursor-pointer\"\n             href=\"/{{Template.RoutePrefix}}/{{Template.RouteNextTemplateSlug}}/create\">\n            Add New\n          </a>\n        </div>\n\n        <div class=\"row gap-4\">\n          <wc-tabulator\n            class=\"w-full rounded\"\n            id=\"[= collectionName =]-table\"\n            ajax-url=\"/api/[= collectionName =]?schema_slug={{Template.Schema}}\"\n            initial-sort='[= sortStr =]'\n            placeholder=\"No Data Available\"\n            movable-columns=\"true\"\n            movable-rows=\"true\"\n            row-header='{\"headerSort\":false, \"resizable\": false, \"minWidth\":30, \"width\":30, \"rowHandle\":true, \"formatter\":\"handle\"}'\n            row-context-menu=\"rowContextMenu\"\n            row-height=\"40\"\n            pagination\n            pagination-size=\"16\"\n            pagination-counter=\"rows\"\n            header-visible=\"true\"\n            selectable-rows=\"true\"\n            layout=\"fitColumns\"\n            >\n            <wc-tabulator-func name=\"onInit\">\n              (table) => {\n                table.allowEdit = false;\n              }\n            </wc-tabulator-func>\n            <wc-tabulator-func name=\"onDelete\">\n              (result) => {\n                wc.Prompt.toast({title: 'Delete successful!', type: 'success'});\n              }\n            </wc-tabulator-func>\n            <wc-tabulator-func name=\"onClone\">\n              (row, result) => {\n                console.log('Clone result: ', result);\n                const table = row.getTable();\n                const selectedData = table.getSelectedData();\n                const recordIds = selectedData.map(m => m._id);\n                result.recordIds = recordIds;\n\n                fetch('/api/clone-records', {\n                  method: 'POST',\n                  headers: { 'Content-Type': 'application/json' },\n                  body: JSON.stringify(result)\n                })\n                .then(response => response.json())\n                .then(data => {\n                  console.log(data);\n                  wc.Prompt.toast({title: 'Clone successful!', type: 'success'});\n                })\n                .catch(error => {\n                  console.error('Error:', error);\n                  wc.Prompt.toast({title: 'Error cloning!', type: 'error'});\n                });\n              }\n            </wc-tabulator-func>\n            <wc-tabulator-column\n              title=\"Actions\"\n              formatter=\"rowSelection\"\n              title-formatter=\"rowSelection\"\n              hoz-align=\"center\"\n              width=45\n              header-sort=\"false\"\n              header-menu=\"headerMenu\"\n              cell-click=\"toggleSelect\"\n              visible=\"true\"\n              ></wc-tabulator-column>\n            <wc-tabulator-column\n              title=\"#\"\n              formatter=\"pageRowNum\"\n              hoz-align=\"center\"\n              width=40\n              header-sort=\"false\"\n              header-menu=\"headerMenu\"\n              ></wc-tabulator-column>\n            [= listHTML =]\n          </wc-tabulator>\n        </div>\n      </div>\n    </div>\n  </div>\n  {%endblock%}\n\n  {%block js%}\n[% if functions %]\n   <script id=\"[= collectionName =]_script\">\n    [= functions =]\n   </script>\n[% endif %]\n  {%endblock%}";