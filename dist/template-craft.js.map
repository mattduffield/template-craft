export default "\n    <div class=\"row gap-4\">\n      <wc-select name=\"[= fullName =]\"\n        mode=\"chip\"\n        class=\"col-1\"\n        lbl-label=\"[= properSuffix =]\"\n        multiple\n        allow-dynamic\n        [= required =]>\n        {% for tag in Record.[= fullName =] %}\n          <option value=\"{{tag}}\" selected>{{tag}}</option>\n        {% endfor %}\n      </wc-select>\n    </div>\n";