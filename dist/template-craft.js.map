export default "<fieldset class=\"flex flex-col p-4 gap-4 border border-solid rounded-md primary-bg-border-color\">\n        <legend class=\"text-lg\">[= proper =]</legend>\n\n        <div class=\"flex flex-row flex-1 justify-end\">\n            <a class=\"underline\"\n               hx-boost=\"true\"\n               href=\"/api/generate_card_fragment_by_schema/{{Template.CollectionName}}\"\n               hx-target=\".card-host\"\n               hx-swap=\"beforeend\"\n               hx-indicator=\"#content-loader\"\n               hx-push-url=\"false\"\n               hx-vals=\"js:{ index: countElements('.card-host .card-item'), schema_slug: '{{Template.Schema}}', property_name: '[= propName =]', record_id: '{{RecordID}}', mode: 'add' }\"\n               _=\"on htmx:afterRequest if detail.successful then\n                  set elem to the first <.no-data/>\n                  if elem\n                    transition the elem's opacity to 0 then settle then remove the elem\n                  end\n                end\">\n              Add New\n            </a>\n          </div>\n\n        {% if Record.[= propName =] %}\n        <div class=\"card-host flex flex-wrap gap-4\">\n          {% for item in Record.[= propName =] %}\n          <div class=\"card-item flex flex-col p-4 gap-4 xw-300 border border-solid rounded-md primary-border-color card relative primary-bg-image-gradient\">\n            <a class=\"underline cursor-pointer absolute top-2 right-2\"\n              hx-delete=\"/api/{{Template.CollectionName}}/{{RecordID}}/[= propName =]/{%forloop.Counter0%}\"\n              hx-target=\"#viewport\"\n              hx-swap=\"none\"\n              hx-indicator=\"#content-loader\"\n              hx-params=\"csrf_token\"\n              hx-headers='{ \"X-CSRF-Token\": \"{{CSRFToken}}\" }'\n              hx-push-url=\"false\"\n              hx-trigger=\"confirm:delete\"\n              _=\"on click\n                set result to wc.Prompt.question({ 'title': 'Confirm Remove?', 'text': 'Are you sure you want to remove?' })\n                if result\n                  trigger 'confirm:delete'\n                end\n              end\n              on htmx:afterRequest if detail.successful then\n                  set elem to the closest <.card-item />\n                  transition the elem's opacity to 0 then settle then remove the elem\n              end\">\n              X\n            </a>\n            [= arrayHTML =]\n          </div>\n          {% endfor %}\n        {% else %}\n          <div class=\"no-data p-8 flex flex-col flex-1 justify-center items-center\">\n            NO DATA\n          </div>\n        {% endif %}\n        </div>\n      </fieldset>";